# ========================================
# DATABASE & CACHE
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/legal_ai
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========================================
# JWT SECURITY
# ========================================
SECRET_KEY=dev-super-secret-key-change-in-production-32chars-2026-legal-ai-xyz789!!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ========================================
# GigaChat API (https://developers.sber.ru/)
# ========================================
GIGACHAT_CLIENT_ID=YOUR_CLIENT_ID_HERE
GIGACHAT_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ========================================
# RAG & AI
# ========================================
RAG_DOCS_PATH=/app/rag_docs
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_DB_TYPE=pgvector
ENABLE_PGVECTOR=true
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ========================================
# App Settings
# ========================================
APP_NAME=Legal AI Service
DEBUG=true
VERSION=1.0.0
ENVIRONMENT=development
API_V1_STR=/api/v1
CORS_ORIGINS=["*"]
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ========================================
# Email Notifications
# ========================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=notify@ai-jurist.ru
SMTP_PASSWORD=your-yandex-app-password
EMAIL_FROM=Legal AI <no-reply@ai-jurist.ru>

# ========================================
# Celery
# ========================================
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=280

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
