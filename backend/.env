# Демо-конфиг (готово к запуску). Локально: Postgres/Redis на localhost. Docker Compose переопределяет хосты db/redis.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/legal_ai
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

SECRET_KEY=dev-super-secret-key-change-in-production-32chars-2026-legal-ai-xyz789!!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

SUPERADMIN_EMAIL=admin@demo.local
SUPERADMIN_PASSWORD=DemoLegal2026!
SUPERADMIN_FULL_NAME=Demo Admin

GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_SCOPE=GIGACHAT_API_PERS

RAG_DOCS_PATH=./rag_docs
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_DB_TYPE=pgvector
ENABLE_PGVECTOR=false
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200

APP_NAME=Legal AI Service
DEBUG=true
VERSION=1.0.0
ENVIRONMENT=development
API_V1_STR=/api/v1
CORS_ORIGINS=["*"]
ALLOWED_HOSTS=localhost,127.0.0.1,87.242.87.53

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=notify@example.com
SMTP_PASSWORD=demo-not-used
EMAIL_FROM=Legal AI <no-reply@example.com>

CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=280

LOG_LEVEL=INFO
LOG_FORMAT=json

# Публичный VPS (для справки). DNS A: ваш поддомен → этот IP
SERVER_PUBLIC_IP=87.242.87.53
# Для Traefik + HTTPS без своего домена: nip.io указывает на IP
TRAEFIK_API_DOMAIN=87-242-87-53.nip.io
ACME_EMAIL=demo@example.com
