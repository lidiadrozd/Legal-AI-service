# ========================================
# DATABASE & CACHE (Docker Compose)
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/legal_ai
REDIS_URL=redis://redis:6379/0

# ========================================
# JWT SECURITY (ОБЯЗАТЕЛЬНО сгенерируйте!)
# ========================================
SECRET_KEY=super-secret-key-change-this-32chars-minimum-2026-legal-ai-service-xyz789!!!abc123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ========================================
# GigaChat API (ОБЯЗАТЕЛЬНО из developers.sber.ru)
# ========================================
GIGACHAT_CLIENT_ID=your_client_id_from_sber_developers_portal
GIGACHAT_CLIENT_SECRET=your_client_secret_from_sber_developers_portal
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ========================================
# RAG & Vector Database
# ========================================
RAG_DOCS_PATH=/app/rag_docs
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_DB_TYPE=pgvector
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ========================================
# Application Settings
# ========================================
APP_NAME=Legal AI Service
DEBUG=True
VERSION=1.0.0
ENVIRONMENT=development

# ========================================
# API & CORS
# ========================================
API_V1_STR=/api/v1
CORS_ORIGINS=*
ALLOWED_HOSTS=localhost,127.0.0.1,api.dev.ai-jurist.ru

# ========================================
# Rate Limiting (Redis)
# ========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================================
# Email (SMTP для уведомлений)
# ========================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Legal AI Service <no-reply@ai-jurist.ru>

# ========================================
# External APIs (опционально)
# ========================================
TAVILY_API_KEY=your_tavily_key_optional
SERPER_API_KEY=your_serper_key_optional

# ========================================
# PostgreSQL pgvector extension
# ========================================
ENABLE_PGVECTOR=True

# ========================================
# Celery (фоновые задачи)
# ========================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=False
